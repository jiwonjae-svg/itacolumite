# ──────────────────────────────────────────────
# Itacolumite – Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────

# Google AI API
GEMINI_API_KEY=your_api_key_here
# 모델 티어: Fast(일반 작업) / Pro(복잡/실패 누적 시 자동 전환)
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_USE_PRO_FOR_VISION=true
GEMINI_AUTO_UPGRADE=true
GEMINI_AUTO_UPGRADE_THRESHOLD=0.3
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=4096

# Agent Settings
AGENT_MAX_STEPS=200
AGENT_LOG_LEVEL=INFO
AGENT_CAPTURE_TARGET=primary-monitor

# Timing (milliseconds)
TYPING_DELAY_MS=50
ACTION_DELAY_MS=200
SCREENSHOT_DELAY_MS=500

# Named Pipe
CONTROL_PIPE_NAME=itacolumite-control

# Grounding / Validation
GROUNDING_MIN_CONFIDENCE=0.45
GROUNDING_POST_CLICK_DIFF_THRESHOLD=0.002
GROUNDING_ENABLE_LOCAL_CROP_RECHECK=true
GROUNDING_ENABLE_EXTERNAL_PROVIDERS=true
GROUNDING_PROVIDER_INPUTS_SUBDIR=grounding/providers

# Gemini OCR provider generation
GROUNDING_ENABLE_GEMINI_OCR_PROVIDER=true
GROUNDING_AUTO_REFRESH_GEMINI_OCR=true
GROUNDING_GEMINI_OCR_OUTPUT_NAME=gemini_ocr_latest.json
GROUNDING_GEMINI_OCR_MAX_ITEMS=40

# OmniParser native runner
GROUNDING_ENABLE_OMNIPARSER_RUNNER=false
GROUNDING_AUTO_REFRESH_OMNIPARSER=false
GROUNDING_OMNIPARSER_COMMAND=
GROUNDING_OMNIPARSER_ARGS=
GROUNDING_OMNIPARSER_WORKDIR=
GROUNDING_OMNIPARSER_TIMEOUT_SEC=60
GROUNDING_OMNIPARSER_OUTPUT_NAME=omniparser_latest.json

GROUNDING_REPORTS_SUBDIR=grounding/reports
